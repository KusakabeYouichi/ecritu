// Copy this file to Config/Signing.local.xcconfig and adjust values for your team.
// This file is tracked; Signing.local.xcconfig is gitignored.

ECRITU_DEVELOPMENT_TEAM = YOUR_TEAM_ID
ECRITU_APP_BUNDLE_IDENTIFIER = com.yourdomain.ecritu
ECRITU_KEYBOARD_BUNDLE_IDENTIFIER = $(ECRITU_APP_BUNDLE_IDENTIFIER).keyboard
ECRITU_TESTS_BUNDLE_IDENTIFIER = $(ECRITU_APP_BUNDLE_IDENTIFIER).tests
ECRITU_APP_GROUP_IDENTIFIER = group.$(ECRITU_APP_BUNDLE_IDENTIFIER)
