	<dict><key>phrase</key><string>そうだ</string><key>shortcut</key><string>そうだ</string></dict>
	<!-- 様態「〜なさそう」は補助形容詞「ない」でかなが正書。過剰漢字化(無さそう/莫さそう)と、だ付与時に なさ+そうだ→莫さ操舵 等へ誤分割されるのを かな全長curatedで抑える -->
	<dict><key>phrase</key><string>なさそう</string><key>shortcut</key><string>なさそう</string></dict>
	<dict><key>phrase</key><string>なさそうだ</string><key>shortcut</key><string>なさそうだ</string></dict>
