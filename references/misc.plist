	<dict><key>phrase</key><string>聞き間違える</string><key>shortcut</key><string>ききまちがえる</string><key>pos</key><string>一段</string></dict>
	<dict><key>phrase</key><string>聞き</string><key>shortcut</key><string>きき</string></dict>
	<!-- 来た は くる の活用形につき辞書に単独収穫されず(きた の辞書は 北/喜田 等のみ)、活用派生7200では 北(5217)やレア人名1ノードに負ける。超高頻度につきcuratedで供給(きゅうにきたよ→急に来たよ 等) -->
	<dict><key>phrase</key><string>来た</string><key>shortcut</key><string>きた</string></dict>
	<!-- すき は word_costs で スキ/隙(3903)が 好き(5215)より安く、すきだった 等の合成語幹で 隙だった/スキだった が先頭に来る。頻度圧倒の 好き をcuratedで先頭化。同型: だいじ(大寺3719<大事4031)、きれい(奇麗3864が最安。1位かな/2位綺麗) -->
	<dict><key>phrase</key><string>好き</string><key>shortcut</key><string>すき</string></dict>
	<dict><key>phrase</key><string>大事</string><key>shortcut</key><string>だいじ</string></dict>
	<dict><key>phrase</key><string>きれい</string><key>shortcut</key><string>きれい</string></dict>
	<dict><key>phrase</key><string>綺麗</string><key>shortcut</key><string>きれい</string></dict>
	<!-- 助動詞相当「かもしれない」はかな正書。辞書に1語で無く かも+知れません(知れる の活用派生)に割れるため、かな識別curatedで全長供給 -->
	<dict><key>phrase</key><string>かもしれない</string><key>shortcut</key><string>かもしれない</string></dict>
	<dict><key>phrase</key><string>かもしれません</string><key>shortcut</key><string>かもしれません</string></dict>
	<dict><key>phrase</key><string>かもしれなかった</string><key>shortcut</key><string>かもしれなかった</string></dict>
	<dict><key>phrase</key><string>かもしれず</string><key>shortcut</key><string>かもしれず</string></dict>
	<!-- ほうが 終止(〜したほうが)で word_costs の 邦画/萌芽 等が勝つのを防ぐ。1位=かな、2位=方が の順(配列順が候補順に効く) -->
	<dict><key>phrase</key><string>ほうが</string><key>shortcut</key><string>ほうが</string></dict>
	<dict><key>phrase</key><string>方が</string><key>shortcut</key><string>ほうが</string></dict>
	<!-- よい は 1位=かな、2位=良い(word_costs最安の 酔い を先頭から退ける)。いい→良い は suppr 側で抑制 -->
	<dict><key>phrase</key><string>よい</string><key>shortcut</key><string>よい</string></dict>
	<dict><key>phrase</key><string>良い</string><key>shortcut</key><string>よい</string></dict>
	<!-- 慣用「〜だけあって」(だけのことはある)はかな正書。あって 区間は派生(会って/逢って)が埋めてかな素通りが生成されず、やつだけ会って 等になる。※「1回だけ会って」等は変種/学習で選択可のトレードオフ -->
	<dict><key>phrase</key><string>だけあって</string><key>shortcut</key><string>だけあって</string></dict>
	<!-- 写真: 実データDPでは 写真の解像度が が明確に最良だが、実機では 者芯 系(過去の検証の学習汚染)に負ける。超高頻度につき追加語彙(2400)で確実に先頭化 -->
	<dict><key>phrase</key><string>写真</string><key>shortcut</key><string>しゃしん</string></dict>
	<!-- 「飲みに行く」慣用: のみ→飲み が高コスト(8469)で かな のみ に沈み、いけます も 生けます が優勢。慣用形を curated で供給 -->
	<dict><key>phrase</key><string>飲みに行く</string><key>shortcut</key><string>のみにいく</string><key>pos</key><string>五段</string></dict>
	<dict><key>phrase</key><string>飲みに行けます</string><key>shortcut</key><string>のみにいけます</string></dict>
	<dict><key>phrase</key><string>飲みに行ける</string><key>shortcut</key><string>のみにいける</string></dict>
	<dict><key>phrase</key><string>飲みに行った</string><key>shortcut</key><string>のみにいった</string></dict>
	<dict><key>phrase</key><string>飲みに行って</string><key>shortcut</key><string>のみにいって</string></dict>
	<dict><key>phrase</key><string>飲みに行こう</string><key>shortcut</key><string>のみにいこう</string></dict>
	<!-- すじょう は コーパスの 巣→城 bigram(1199=地名由来)で 巣城(す+城 2ノード)が 素性(1ノード7873)を連文節で逆転する。常用語 素性 をcuratedで先頭化 -->
	<dict><key>phrase</key><string>素性</string><key>shortcut</key><string>すじょう</string></dict>
	<!-- ときは は トキハ(大分の百貨店等の固有名、4379)が最安。1位かな/2位 時は の順に(トキハ は実在固有名につき抑制せず後方へ) -->
	<dict><key>phrase</key><string>ときは</string><key>shortcut</key><string>ときは</string></dict>
	<dict><key>phrase</key><string>時は</string><key>shortcut</key><string>ときは</string></dict>
	<!-- ある(動詞)はかなが正書(公用文基準)。全かな あるといいな 等がエコーガードで捨てられ 有る系変種が繰り上がるのを防ぐ -->
	<dict><key>phrase</key><string>ある</string><key>shortcut</key><string>ある</string></dict>
	<!-- 口語の「やつ」(物・人を指す)はかなが正書(奴 は乱暴な字面、八つ は数詞複合派生)。やつだけあって 等の慣用にも効く -->
	<dict><key>phrase</key><string>やつ</string><key>shortcut</key><string>やつ</string></dict>
	<!-- 否定過去「なかった」はかなが正書(〜がなかった)。無かった の派生に負けるうえ、長文では変種枠(3件)から押し出されて かな が消える。かな全長curatedで最良化(無かった は2位に残る) -->
	<dict><key>phrase</key><string>なかった</string><key>shortcut</key><string>なかった</string></dict>
	<!-- 終助詞クラスタ「だよねえ/だよね」はかな。ねえ→姉/姐、だ→打/駄 等の漢字化やカタカナ混じりに割れるため かな全長curatedで供給 -->
	<dict><key>phrase</key><string>だよねえ</string><key>shortcut</key><string>だよねえ</string></dict>
	<dict><key>phrase</key><string>だよね</string><key>shortcut</key><string>だよね</string></dict>
	<dict><key>phrase</key><string>だよなあ</string><key>shortcut</key><string>だよなあ</string></dict>
	<!-- 形式名詞「こと」の否定慣用(することはない/することない)はかなが正書。ことは の word_costs はレア人名(寿羽等)だけで 事は/ことは 単位が無く 事はない/寿羽ない に負ける -->
	<dict><key>phrase</key><string>ことはない</string><key>shortcut</key><string>ことはない</string></dict>
	<dict><key>phrase</key><string>ことない</string><key>shortcut</key><string>ことない</string></dict>
	<!-- 形式名詞「ところ」はかなが正書(ところもあるが 等)。LMは全かなを最良にするが、全かなエコーガードは curated を含む経路しか返さないため、かな識別curatedで供給して先頭に残す -->
	<dict><key>phrase</key><string>ところ</string><key>shortcut</key><string>ところ</string></dict>
	<!-- 助詞相当「によって/により/による」はかなが正書。word_costs に よって/によって が無く、活用派生(寄って/似寄って=似寄る の て形)がノードを埋めて かな素通りが生成されないため、会社似寄って が最良になる。かな識別curatedで供給 -->
	<dict><key>phrase</key><string>によって</string><key>shortcut</key><string>によって</string></dict>
	<dict><key>phrase</key><string>により</string><key>shortcut</key><string>により</string></dict>
	<dict><key>phrase</key><string>による</string><key>shortcut</key><string>による</string></dict>
	<!-- 副詞「きっと」はかなが正書。word_cost/unigram とも キット(kit名詞)が安く既定で勝つが、主要IMEはいずれも きっと(ひらがな)既定。かな正書curatedで先頭化(スターターキット等 katakana複合の一部は#2に落ちるトレードオフ) -->
	<dict><key>phrase</key><string>きっと</string><key>shortcut</key><string>きっと</string></dict>
	<!-- 接続の慣用「だけでなく/だけではなく」はかなが正書。なく の word_cost は 泣く(9509)が かな なく(10363)より安く、だけで+泣く が最良になる。かな全長curatedで先頭化 -->
	<dict><key>phrase</key><string>だけでなく</string><key>shortcut</key><string>だけでなく</string></dict>
	<dict><key>phrase</key><string>だけではなく</string><key>shortcut</key><string>だけではなく</string></dict>
	<!-- ほんとう→本当 を先頭化。ryukyu.plist の 本島(ほんとう=沖縄本島)が curated 上位で 本当(systemDictionary)を潰すため、本当 も curated で供給して先頭に戻す -->
	<dict><key>phrase</key><string>本当</string><key>shortcut</key><string>ほんとう</string></dict>
</array>
</plist>
